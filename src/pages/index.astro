---
import Base from "../layouts/Base.astro";
---

<Base title="nico.codes">
  <div id="hero" class="fixed inset-0">
    <div id="field-wrap" class="absolute inset-0" style="touch-action: none;">
      <canvas id="field"></canvas>
    </div>

    <h1 id="hero-title" class="pointer-events-none absolute select-none font-bold tracking-tight z-10">nico.codes</h1>

    <nav id="hero-nav" class="pointer-events-auto absolute flex z-10">
      <a
        href="/notes"
        class="font-bold tracking-tight text-white/40 hover:text-white transition-colors select-none"
      >
        Notes
      </a>
      <a
        href="/about"
        class="font-bold tracking-tight text-white/40 hover:text-white transition-colors select-none"
      >
        About
      </a>
    </nav>
  </div>

  <style>
    /* Mobile: text outside field */
    #hero-title {
      top: 1rem;
      left: 2rem;
      font-size: 2.25rem; /* text-4xl */
    }
    #hero-nav {
      bottom: 1rem;
      right: 2rem;
      gap: 2rem;
    }
    #hero-nav a {
      font-size: 2.25rem; /* text-4xl */
    }
    #field-wrap {
      top: 3rem;
      bottom: 3rem;
    }

    /* Soft blur glow behind text */
    #hero-title::before,
    #hero-nav::before {
      content: "";
      position: absolute;
      inset: -3rem -4rem;
      background: radial-gradient(ellipse at center, rgba(5,6,7,0.95) 0%, rgba(5,6,7,0.6) 40%, rgba(5,6,7,0) 70%);
      z-index: -1;
      pointer-events: none;
    }

    /* Desktop: full-screen overlay */
    @media (min-width: 800px) {
      #hero-title {
        top: auto;
        bottom: 3rem;
        left: 3rem;
        font-size: 4.5rem; /* text-7xl */
      }
      #hero-nav {
        bottom: 3rem;
        right: 3rem;
        gap: 2.5rem;
      }
      #hero-nav a {
        font-size: 3rem; /* text-5xl */
      }
      #field-wrap {
        top: 0;
        bottom: 0;
      }
    }
  </style>

  <script>
    import { init } from "../components/FlowField";

    let destroy: (() => void) | null = null;

    function start() {
      destroy?.();
      const canvas = document.getElementById("field") as HTMLCanvasElement | null;
      const container = document.getElementById("field-wrap") as HTMLDivElement | null;
      if (canvas && container) {
        destroy = init(canvas, container);
      }
    }

    start();
    document.addEventListener("astro:after-swap", start);
  </script>
</Base>
