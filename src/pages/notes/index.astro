---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Base title="Notes — nico.codes">
  <Header />
  <main class="mx-auto max-w-[720px] px-8 pt-6 sm:pt-14 pb-16">
    <p class="text-sm text-white/30 mb-4 sm:mb-10">Irregularly updated, occasionally useful.</p>
    {posts.length > 0 ? (
      <ul class="list-none p-0 m-0 flex flex-col gap-2">
        {posts.map((post) => (
          <li>
            <a
              href={`/notes/${post.id}`}
              class="group grid grid-cols-[1fr_auto] gap-6 items-baseline py-[18px] px-4 rounded-xl border border-white/[0.06] transition-colors duration-150 hover:bg-white/[0.03] hover:border-white/[0.12] active:bg-white/[0.05]"
            >
              <div>
                <div class="text-[17px] font-medium text-white/80 tracking-tight group-hover:text-white transition-colors">{post.data.title}</div>
                <div class="text-sm text-white/40 mt-1 leading-relaxed group-hover:text-white/60 transition-colors">{post.data.description}</div>
              </div>
              <span class="text-white/30 text-xs font-mono text-right">{formatDate(post.data.pubDate)}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-white/40">No posts yet.</p>
    )}
  </main>
</Base>
