---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";

const projects = [
  {
    name: "numpy-ts",
    href: "https://numpyts.dev",
    logo: "/logos/numpy-ts.svg",
    description: "Fast, Complete NumPy for TypeScript & JavaScript",
  },
  {
    name: "CyborgDB",
    href: "https://docs.cyborg.co",
    logo: "/logos/cyborgdb.svg",
    description: "Application-Layer Security for AI Knowledge & Memory",
  },
  {
    name: "Stealth",
    href: "https://cyborg.co/stealth",
    logo: "/logos/stealth.svg",
    description: "End-to-End Encrypted, Searchable Cloud Storage",
  },
  {
    name: "Overhead",
    href: "https://overhead.cloud/",
    logo: "/logos/overhead.svg",
    description: "Augmented Reality Flight Spotter for iOS",
  }
];
---

<Base title="About — nico.codes">
  <Header />
  <main class="mx-auto max-w-3xl px-6 pt-8 pb-16">
    <div class="sm:flex sm:gap-12">
      <div class="shrink-0 self-start">
        <div class="group relative w-40 aspect-square overflow-hidden rounded-2xl sm:w-52">
          <img
            src="/portraits/cap-composite.webp"
            alt=""
            aria-hidden="true"
            class="absolute inset-0 h-full w-full"
          />
          <img
            src="/portraits/cap-color.webp"
            alt="Nico Dupont"
            class="absolute inset-0 h-full w-full opacity-0 transition-opacity duration-500 group-hover:opacity-100"
          />
        </div>

        <div class="mt-4 flex w-40 items-center gap-4 sm:w-52">
          <a
            href="https://github.com/dupontcyborg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-white/40 hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.33.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.26 1.89-.39 2.86-.39.97 0 1.95.13 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.26 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
          </a>
          <a
            href="https://linkedin.com/in/cyborgnico"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-white/40 hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
        </div>
      </div>

      <div class="mt-8 sm:mt-0">
        <h1 class="text-3xl font-bold tracking-tight">Hi, I'm Nico Dupont.</h1>

        <div class="mt-6 text-white/70 leading-relaxed space-y-4">
          <p>
            I'm a software engineer from Paris, based in New York. I run <a href="https://cyborg.co" target="_blank" rel="noopener noreferrer" class="text-white hover:text-white/70 underline underline-offset-2 transition-colors">Cyborg</a> and spend most of my spare time building things — some ship, some don't. I also <a href="/blog" class="text-white hover:text-white/70 underline underline-offset-2 transition-colors">write</a> when something's worth saying.
          </p>
        </div>

        <h2 class="mt-10 text-sm font-medium uppercase tracking-widest text-white/30">Select projects</h2>

        <div class="mt-4 grid gap-3">
          {projects.map((project) => (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 rounded-xl border border-white/10 px-4 py-3 transition-colors hover:border-white/25 hover:bg-white/[0.03]"
            >
              <img
                src={project.logo}
                alt={`${project.name} logo`}
                class="h-8 w-8 shrink-0"
              />
              <div>
                <span class="text-sm font-medium text-white">{project.name}</span>
                <p class="text-xs text-white/40">{project.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>
</Base>
