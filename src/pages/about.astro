---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";

const projects = [
  {
    name: "numpy-ts",
    desc: "Fast, complete NumPy for TypeScript & JavaScript.",
    url: "numpyts.dev",
    logo: "/logos/numpy-ts.svg",
    year: "2026",
  },
  {
    name: "Overhead",
    desc: "Augmented reality flight spotter for iOS.",
    url: "overhead.cloud",
    logo: "/logos/overhead.svg",
    year: "2025",
  },
  {
    name: "CyborgDB",
    desc: "Application-layer security for AI knowledge & memory.",
    url: "www.cyborg.co",
    logo: "/logos/cyborgdb.svg",
    year: "2024",
  },
  {
    name: "Stealth",
    desc: "End-to-end encrypted, searchable cloud storage.",
    url: "cyborg.co/stealth",
    logo: "/logos/stealth.svg",
    year: "2022",
  },

];
---

<Base title="About — nico.codes">
  <Header />
  <main class="mx-auto max-w-[780px] px-8 pt-14 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-9 items-start">
      <div>
        <div class="group relative w-[200px] h-[260px] overflow-hidden rounded-xl">
          <img
            src="/portraits/glasses-color.webp"
            alt="Nico Dupont"
            class="absolute inset-0 h-full w-full object-cover"
          />
        </div>
      </div>

      <div>
        <h1 class="text-[26px] font-semibold tracking-tight leading-tight m-0 mb-2.5" style="letter-spacing: -0.02em;">
          Hi, I'm Nico Dupont.
        </h1>
        <p class="mt-[18px] text-[16px] leading-[1.75] text-white/70">
          I'm a software engineer from Paris, based in New York. I run <a href="https://cyborg.co" target="_blank" rel="noopener noreferrer" class="text-white hover:text-white/70 underline underline-offset-2 decoration-white/25 hover:decoration-white/50 transition-colors">Cyborg</a> and spend most of my time building things (some ship, most don't). I really enjoy working on performance optimization and applied cryptography, and sometimes I <a href="/notes" class="text-white hover:text-white/70 underline underline-offset-2 decoration-white/25 hover:decoration-white/50 transition-colors">write</a>.
        </p>
        <p class="mt-[10px] text-[16px] leading-[1.75] text-white/70">
          Outside of being an absolute nerd, I'm a big football/soccer fan (Allez les Bleus & Ici c'est Paris!) and an avid snowboarder.
        </p>
        <div class="mt-4 flex items-center gap-4">
          <a
            href="https://github.com/dupontcyborg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-white/40 hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.33.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.26 1.89-.39 2.86-.39.97 0 1.95.13 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.26 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
          </a>
          <a
            href="https://linkedin.com/in/cyborgnico"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-white/40 hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <section class="mt-14">
      <h2 class="text-[13px] font-medium text-white/30 m-0 mb-5 tracking-wider uppercase">
        Some of my projects
      </h2>
      <ul class="list-none p-0 m-0">
        {projects.map((p, i) => (
          <li>
            {i > 0 && <div class="h-px bg-white/[0.08] mx-2"></div>}
            <a
              href={`https://${p.url}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group grid grid-cols-[24px_100px_1fr] sm:grid-cols-[24px_120px_1fr_60px] gap-4 items-center py-4 px-4 -mx-4 rounded-lg transition-colors duration-150 hover:bg-white/[0.03]"
            >
              <img src={p.logo} alt="" class="h-5 w-5 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity" />
              <span class="text-[15px] text-white/80 font-medium group-hover:text-white transition-colors">{p.name}</span>
              <span class="text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors">{p.desc}</span>
              <span class="hidden sm:block text-xs text-white/30 font-mono text-right">{p.year}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Base>
