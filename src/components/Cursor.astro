---
---

<div id="cursor" aria-hidden="true" transition:persist>
  <div id="cursor-ring"></div>
  <div id="cursor-dot"></div>
</div>

<script>
  if (window.matchMedia("(pointer: fine)").matches) {
    const interactiveSelector =
      'a, button, [role="button"], input[type="submit"], input[type="button"], label[for]';

    let lastX = 0;
    let lastY = 0;
    let hasMoved = false;

    function activate() {
      document.documentElement.setAttribute("data-cursor", "active");
      // Restore visibility after View Transition swap (mouseleave fires during swap)
      if (hasMoved) {
        document.getElementById("cursor")?.classList.add("visible");
      }
    }

    function setPos(x: number, y: number) {
      lastX = x;
      lastY = y;
      const cursor = document.getElementById("cursor");
      const dot = document.getElementById("cursor-dot");
      const ring = document.getElementById("cursor-ring");
      if (!cursor || !dot || !ring) return;
      const t = `translate3d(${x}px, ${y}px, 0) translate(-50%, -50%)`;
      dot.style.transform = t;
      ring.style.transform = t;
      cursor.classList.add("visible");
      hasMoved = true;
    }

    activate();

    window.addEventListener("mousemove", (e) => setPos(e.clientX, e.clientY));

    document.addEventListener("mouseleave", () => {
      document.getElementById("cursor")?.classList.remove("visible");
      hasMoved = false;
    });
    document.addEventListener("mouseenter", () => {
      document.getElementById("cursor")?.classList.add("visible");
      hasMoved = true;
    });

    document.addEventListener("mouseover", (e) => {
      const target = e.target as HTMLElement | null;
      if (target?.closest?.(interactiveSelector)) {
        document.getElementById("cursor")?.classList.add("hover");
      }
    });

    document.addEventListener("mouseout", (e) => {
      const target = e.target as HTMLElement | null;
      if (target?.closest?.(interactiveSelector)) {
        document.getElementById("cursor")?.classList.remove("hover");
      }
    });

    document.addEventListener("astro:after-swap", activate);
    document.addEventListener("astro:page-load", activate);
  }
</script>
