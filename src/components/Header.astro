---
const path = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="mx-auto flex max-w-3xl items-center justify-between px-6 py-6">
  <a href="/" class="text-sm font-medium tracking-tight text-white hover:text-white/70 transition-colors">
    nico.codes
  </a>
  <nav class="flex gap-6">
    <a
      href="/about"
      class:list={[
        "text-sm tracking-wide transition-colors",
        isActive("/about") ? "text-white" : "text-white/40 hover:text-white/70",
      ]}
    >
      About
    </a>
    <a
      href="/blog"
      class:list={[
        "text-sm tracking-wide transition-colors",
        isActive("/blog") ? "text-white" : "text-white/40 hover:text-white/70",
      ]}
    >
      Blog
    </a>
  </nav>
</header>
