---
import Base from "./Base.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  ogImage?: string;
  toc?: boolean;
}

const { title, description, pubDate, updatedDate, ogImage, toc = true } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

function formatDateLong(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Base title={`${title} — nico.codes`} description={description} ogImage={ogImage}>
  <Header />
  <main id="post-main" class="mx-auto max-w-[880px] px-8 pt-14 pb-16 grid grid-cols-1 gap-12">
    <article>
      <div class="text-xs text-white/30 font-mono">
        {formatDate(pubDate)}
      </div>
      <h1 class="text-[32px] font-semibold tracking-tight leading-tight mt-2.5 mb-3.5" style="letter-spacing: -0.02em;">
        {title}
      </h1>
      <p class="text-[15px] text-white/55 leading-relaxed m-0">
        {description}
      </p>

      {updatedDate && (
        <div class="text-xs text-white/25 mt-2">
          Updated {formatDateLong(updatedDate)}
        </div>
      )}

      <div class="h-px bg-white/[0.08] my-7"></div>

      <div class="max-w-none post-body">
        <slot />
      </div>
    </article>

    {toc && (
      <aside id="post-outline" class="hidden text-[13px] text-white/55 leading-relaxed">
        <div class="sticky top-6">
          <div class="text-white/30 mb-3 text-[11px] tracking-wider uppercase">Contents</div>
          <nav id="outline-nav"></nav>
        </div>
      </aside>
    )}
  </main>

  <style>
    @media (min-width: 960px) {
      #post-main {
        grid-template-columns: 1fr 160px;
      }
      #post-outline {
        display: block;
      }
    }
  </style>

  <script>
    function initOutline() {
      const nav = document.getElementById("outline-nav");
      const article = document.querySelector(".post-body");
      if (!nav || !article) return;

      const headings = article.querySelectorAll("h2, h3");
      if (headings.length === 0) {
        const outline = document.getElementById("post-outline");
        if (outline) outline.style.display = "none";
        // Collapse to single column when no TOC
        document.getElementById("post-main")?.style.setProperty("grid-template-columns", "1fr");
        return;
      }

      nav.innerHTML = "";
      const ids: string[] = [];

      headings.forEach((h, i) => {
        if (!h.id) {
          h.id = `sec-${i}`;
        }
        ids.push(h.id);

        const isH3 = h.tagName === "H3";
        const link = document.createElement("a");
        link.href = `#${h.id}`;
        link.textContent = h.textContent || "";
        Object.assign(link.style, {
          display: "block",
          padding: "2px 0 2px 8px",
          marginLeft: isH3 ? "10px" : "0",
          borderLeft: "2px solid rgba(245,247,250,0.08)",
          color: "rgba(245,247,250,0.4)",
          textDecoration: "none",
          cursor: "pointer",
          transition: "color 200ms, border-left-color 200ms",
          fontSize: isH3 ? "12px" : "13px",
        });
        link.addEventListener("mouseenter", () => { link.style.color = "rgba(245,247,250,0.7)"; });
        link.addEventListener("mouseleave", () => {
          if (!link.dataset.active) link.style.color = "rgba(245,247,250,0.4)";
        });
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const el = document.getElementById(h.id);
          el?.scrollIntoView({ behavior: "smooth", block: "start" });
        });
        nav.appendChild(link);
      });

      function updateActive() {
        let activeId = ids[0];
        for (const id of ids) {
          const el = document.getElementById(id);
          if (!el) continue;
          const top = el.getBoundingClientRect().top;
          if (top <= 80) activeId = id;
        }
        nav.querySelectorAll("a").forEach((a: HTMLAnchorElement) => {
          const isActive = a.getAttribute("href") === `#${activeId}`;
          a.dataset.active = isActive ? "true" : "";
          a.style.borderLeftColor = isActive ? "rgba(245,247,250,0.5)" : "rgba(245,247,250,0.08)";
          a.style.color = isActive ? "rgb(245,247,250)" : "rgba(245,247,250,0.4)";
        });
      }

      updateActive();
      window.addEventListener("scroll", updateActive, { passive: true });
    }

    initOutline();
    document.addEventListener("astro:after-swap", initOutline);
  </script>
</Base>
