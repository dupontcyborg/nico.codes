---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Cursor from "../components/Cursor.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title,
  description = "nico.codes — personal site and notes",
  ogImage = "/social/og-default.png",
  ogType = "website",
  pubDate,
  updatedDate,
} = Astro.props;

const siteUrl = Astro.site ?? Astro.url;
const ogImageAbsolute = new URL(ogImage, siteUrl).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="nico.codes" />
    <meta property="og:type" content={ogType} />
    {ogType === "article" && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {ogType === "article" && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {ogType === "article" && (
      <meta property="article:author" content="Nicolas Dupont" />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="nico.codes"
      href="/rss.xml"
    />
    <ClientRouter />
    {/* Plausible analytics, proxied through the shared CloudFront distribution
        so privacy-focused adblockers don't drop the script or /api/event POSTs.
        Queue shim lets us call window.plausible(...) before the script loads. */}
    <script is:inline>
      window.plausible = window.plausible || function () {
        (window.plausible.q = window.plausible.q || []).push(arguments);
      };
    </script>
    <script defer data-domain="nico.codes" src="https://d1w0psmo3bkh8z.cloudfront.net/js/script.js" is:inline></script>
  </head>
  <body class="bg-[rgb(5,6,7)] text-[rgb(245,247,250)] antialiased">
    <Cursor />
    <slot />
  </body>
</html>
